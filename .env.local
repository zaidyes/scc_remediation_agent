# ── Local test environment ──────────────────────────────────────────────────
# Copy this to .env and fill in your real values before running locally.
# None of these values are secrets — secrets stay in Secret Manager in prod.

# Your GCP project that has Firestore, Vertex AI, and billing enabled.
# Does NOT need to be the org's prod project — a test project works fine.
GOOGLE_CLOUD_PROJECT=your-test-project-id

# Your GCP organisation ID (numeric, found in Cloud Console → IAM → Settings)
ORG_ID=123456789012

# Vertex AI (set False to use AI Studio API key instead — see GOOGLE_API_KEY below)
GOOGLE_GENAI_USE_VERTEXAI=True
GOOGLE_CLOUD_LOCATION=us-central1

# Model IDs (defaults are fine; change if you have allowlist access)
MODEL_ID=gemini-3-flash-preview
PLANNING_MODEL_ID=gemini-3.1-pro-preview

# Uncomment if using AI Studio (GOOGLE_GENAI_USE_VERTEXAI=False)
# GOOGLE_API_KEY=your-ai-studio-api-key

# ── Neo4j (docker-compose spins this up) ────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=localpassword

# ── Firestore ────────────────────────────────────────────────────────────────
# Option A: use the Firestore emulator from docker-compose
FIRESTORE_EMULATOR_HOST=localhost:8080
FIRESTORE_DATABASE=

# Option B: use real Firestore — comment out FIRESTORE_EMULATOR_HOST above
# and set GOOGLE_CLOUD_PROJECT to a project that has Firestore enabled.

# ── Customer config ──────────────────────────────────────────────────────────
# ID you'll use when running the agent. Seed script writes this to Firestore.
CUSTOMER_ID=local-test

# ── Disable Cloud Tasks (not needed for dry-run) ─────────────────────────────
# Leave these blank — the agent skips Cloud Tasks enqueue when URLs are empty.
SCHEDULER_SERVICE_URL=
CLOUD_TASKS_QUEUE=
