# Google Cloud project configuration
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Vertex AI (required for GCP deployment; set to False for local AI Studio testing)
GOOGLE_GENAI_USE_VERTEXAI=True

# Model selection (override defaults)
MODEL_ID=gemini-3-flash-preview
PLANNING_MODEL_ID=gemini-3.1-pro-preview

# Neo4j asset graph
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password

# Firestore database (leave blank for default "(default)" database)
FIRESTORE_DATABASE=

# Notification integrations (stored in Secret Manager on activation)
JIRA_API_TOKEN=your-jira-api-token
JIRA_EMAIL=your-jira-user@example.com

# Cloud Tasks queue for approval escalations and execution
CLOUD_TASKS_QUEUE=scc-remediation-tasks
CLOUD_TASKS_LOCATION=us-central1
SCHEDULER_SERVICE_URL=https://your-scheduler-service-url

# UI API backend
UI_API_PORT=8080
